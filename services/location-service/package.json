{
  "name": "@foodrush/location-service",
  "version": "1.0.0",
  "description": "FoodRush location service with Redis geospatial operations and geofence triggers",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/sensible": "^6.0.0",
    "ioredis": "^5.4.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  }
}
