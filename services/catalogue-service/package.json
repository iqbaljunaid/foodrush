{
  "name": "@foodrush/catalogue-service",
  "version": "1.0.0",
  "description": "FoodRush catalogue service with menu CRUD and OCI Object Storage image uploads",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/sensible": "^6.0.0",
    "oracle-nosqldb": "^5.5.0",
    "oci-nosql": "^2.89.0",
    "oci-objectstorage": "^2.89.0",
    "oci-common": "^2.89.0",
    "oci-secrets": "^2.89.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.3.0"
  }
}
